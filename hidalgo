  /* ---------- Validadores ---------- */
  const CURP_RE = /^[A-Z][AEIOUX][A-Z]{2}\d{2}(0[1-9]|1[0-2])(0[1-9]|[12]\d|3[01])[HM](AS|BC|BS|CC|CL|CM|CS|CH|DF|DG|GT|GR|HG|JC|MC|MN|MS|NT|NL|OC|PL|QT|QR|SP|SL|SR|TC|TS|TL|VZ|YN|ZS|NE)[B-DF-HJ-NP-TV-Z]{3}[A-Z\d]\d$/;
  const RFC_RE = /^[A-ZÑ&]{3,4}\d{6}[A-Z\d]{3}$/;
  const EMAIL_RE = /^[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}$/i;
  // Proveedores comunes para detectar dominios mal escritos (gmaol.cox → gmail.com).
  const EMAIL_PROVEEDORES = ["gmail.com", "hotmail.com", "hotmail.es", "outlook.com", "outlook.es", "yahoo.com", "yahoo.com.mx", "live.com", "live.com.mx", "icloud.com", "prodigy.net.mx"];
  function lev(a, b) {
    const m = a.length, n = b.length, d = Array.from({ length: m + 1 }, (_, i) => [i].concat(Array(n).fill(0)));
    for (let j = 0; j <= n; j++) d[0][j] = j;
    for (let i = 1; i <= m; i++) for (let j = 1; j <= n; j++)
      d[i][j] = Math.min(d[i - 1][j] + 1, d[i][j - 1] + 1, d[i - 1][j - 1] + (a[i - 1] === b[j - 1] ? 0 : 1));
    return d[m][n];
  }
  // Si el dominio se parece a un proveedor conocido pero no es igual, devuelve la sugerencia.
  function emailTipo(v) {
    const dom = (v || "").toLowerCase().split("@")[1] || "";
    if (!dom || EMAIL_PROVEEDORES.includes(dom)) return "";
    let best = "", bd = 99;
    for (const p of EMAIL_PROVEEDORES) { const d = lev(dom, p); if (d < bd) { bd = d; best = p; } }
    return bd <= 2 ? best : "";
  }
  const V = {
    curp: (v) => CURP_RE.test((v || "").toUpperCase()),
    rfc: (v) => RFC_RE.test((v || "").toUpperCase()),
    email: (v) => { const t = (v || "").trim().toLowerCase(); return EMAIL_RE.test(t) && !emailTipo(t); },
    tel: (v) => (v || "").replace(/\D/g, "").length === 10,
    cp: (v) => /^\d{5}$/.test((v || "").trim()),
    text: (v) => (v || "").trim().length >= 2,
  };

  const ERR = {
    curp: "CURP inválida. Revisa los 18 caracteres.",
    rfc: "RFC con formato no válido (SAT).",
    email: "Correo no válido (falta @ o dominio).",
    tel: "Debe tener exactamente 10 dígitos.",
    cp: "El código postal debe tener 5 dígitos.",
    text: "Este campo es obligatorio.",
  };

  const $ = (s, r = document) => r.querySelector(s);
  const $$ = (s, r = document) => Array.from(r.querySelectorAll(s));

  /* ---------- Estado ---------- */
  const state = {
    curpInfo: null,        // { fechaNac, sexo } derivado de la CURP
    cpData: null,
    course: null,          // id
    horario: null,
    comprobante: null,     // File-like {name,size}
    fiscal: null,
    factura: false,
  };

  /* ---------- Helpers de campo ---------- */
  function setFieldState(name, status, msg) {
    const field = $(`[data-field="${name}"]`);
    if (!field) return;
    field.classList.remove("valid", "error");
    const trail = field.querySelector("[data-trail]");
    const hint = field.querySelector(".hint");
    if (status === "valid") {
      field.classList.add("valid");
      if (trail) trail.innerHTML = ICON.check;
      if (hint && hint.dataset.keep !== "1") { hint.className = "hint muted"; hint.innerHTML = hint.dataset.default || ""; }
    } else if (status === "error") {
      field.classList.add("error");
      if (trail) trail.innerHTML = ICON.alert;
      if (hint) { hint.className = "hint err"; hint.innerHTML = ICON.info + " " + msg; }
    } else {
      if (trail) trail.innerHTML = "";
      if (hint && hint.dataset.keep !== "1") { hint.className = "hint muted"; hint.innerHTML = hint.dataset.default || ""; }
    }
  }

  const ICON = {
    check: '<span class="tick"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5 10 17.5 19.5 7"/></svg></span>',
    alert: '<span class="cross"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 1.5 21h21L12 3Zm0 6v6m0 3v.5"/></svg></span>',
    info: '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:1px"><path d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Zm0-9v5m0-9v.5"/></svg>',
    spin: '<svg class="spin" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 3a9 9 0 1 0 9 9" /></svg>',
    file: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3h8l4 4v14H6zM14 3v4h4"/></svg>',
    x: '<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 6l12 12M18 6 6 18"/></svg>',
  };

  // store default hints
  $$(".hint").forEach((h) => { h.dataset.default = h.innerHTML; });

  /* ---------- Formateo de teléfono ---------- */
  function fmtPhone(v) {
    const d = (v || "").replace(/\D/g, "").slice(0, 10);
    if (d.length <= 2) return d;
    if (d.length <= 6) return d.slice(0, 2) + " " + d.slice(2);
    return d.slice(0, 2) + " " + d.slice(2, 6) + " " + d.slice(6);
  }

  /* ---------- Validación genérica con feedback ---------- */
  function bindField(id, type, { onValid, liveError } = {}) {
    const el = $("#" + id);
    if (!el) return;
    const name = el.closest("[data-field]")?.dataset.field || id;
    const run = (revealError) => {
      const val = el.value;
      const has = (val || "").trim().length > 0;
      if (!has) { setFieldState(name, revealError ? "error" : "idle", "Este campo es obligatorio."); update(); return; }
      const ok = V[type](val);
      setFieldState(name, ok ? "valid" : (revealError ? "error" : "idle"), ERR[type]);
      if (ok && onValid) onValid(val);
      update();
    };
    el.addEventListener("input", () => run(liveError === true));
    el.addEventListener("blur", () => run(true));
    el._validate = () => { const ok = V[type](el.value); setFieldState(name, ok ? "valid" : "error", ERR[type]); return ok; };
    el._isValid = () => V[type](el.value);
  }

  /* =================================================================
     1. CURP + RENAPO
     ================================================================= */
  const curpEl = $("#curp");
  curpEl.addEventListener("input", () => {
    curpEl.value = curpEl.value.toUpperCase().replace(/[^A-Z0-9]/g, "").slice(0, 18);
    const name = "curp";
    const val = curpEl.value;
    if (val.length === 0) { setFieldState(name, "idle"); hideRenapo(); update(); return; }
    const ok = V.curp(val);
    setFieldState(name, ok ? "valid" : (val.length >= 18 ? "error" : "idle"), ERR.curp);
    if (ok) revealIdentidad(val); else hideRenapo();
    checkInitials();
    update();
  });
  curpEl.addEventListener("blur", () => {
    if (curpEl.value && !V.curp(curpEl.value)) setFieldState("curp", "error", ERR.curp);
  });

  const renapoStatus = $("#renapoStatus");
  const renapoFields = $("#renapoFields");

  function hideRenapo() {
    state.curpInfo = null;
    renapoStatus.classList.add("hidden");
    renapoFields.classList.add("hidden");
    applyAgeRules();
  }

  // Deriva fecha de nacimiento y sexo a partir de la propia CURP (sin RENAPO).
  function parseCurp(curp) {
    const yy = +curp.slice(4, 6), mm = curp.slice(6, 8), dd = curp.slice(8, 10);
    const homo = curp[16];                         // 17ª posición (homoclave)
    const siglo = /[0-9]/.test(homo) ? 1900 : 2000; // dígito → s.XX, letra → s.XXI
    const fechaNac = `${siglo + yy}-${mm}-${dd}`;
    const sexo = curp[10] === "H" ? "Hombre" : curp[10] === "M" ? "Mujer" : "—";
    return { fechaNac, sexo };
  }

  function revealIdentidad(curp) {
    const info = parseCurp(curp);
    state.curpInfo = info;
    renapoStatus.className = "renapo-status found";
    renapoStatus.innerHTML = ICON.check.replace('width="18" height="18"', 'width="16" height="16"') + " CURP válida · detectamos fecha de nacimiento y sexo. Completa tu nombre.";
    renapoStatus.classList.remove("hidden");
    $('[data-ro="fechaNac"]').textContent = fmtDate(info.fechaNac);
    $('[data-ro="fechaNac"]').classList.remove("empty");
    $('[data-ro="sexo"]').textContent = info.sexo;
    $('[data-ro="sexo"]').classList.remove("empty");
    $('[data-ro="edad"]').textContent = calcAge(info.fechaNac) + " años";
    $('[data-ro="edad"]').classList.remove("empty");
    if (renapoFields.classList.contains("hidden")) {
      renapoFields.classList.remove("hidden");
      renapoFields.classList.add("fade-in");
    }
    applyAgeRules();
    recheckCourseAge();
  }

  function fmtDate(iso) { const [y, m, d] = iso.split("-"); return `${d}/${m}/${y}`; }
  function calcAge(iso) {
    const b = new Date(iso), n = new Date();
    let a = n.getFullYear() - b.getFullYear();
    if (n.getMonth() < b.getMonth() || (n.getMonth() === b.getMonth() && n.getDate() < b.getDate())) a--;
    return a;
  }

  /* =================================================================
     2. Contacto — teléfonos, correo, CP autollenado
     ================================================================= */
  // Parentescos en los selects de responsables y emergencia
  const PARENTESCOS = ["Padre", "Madre", "Tutor(a)", "Abuelo(a)", "Tío(a)", "Hermano(a)", "Otro"];
  $$(".parentesco").forEach((sel) => {
    sel.innerHTML = '<option value="">Selecciona…</option>' + PARENTESCOS.map((p) => `<option>${p}</option>`).join("");
  });

  // Un parentesco usado en un contacto se deshabilita en los demás ("Otro" sí se repite).
  function refreshParentescos() {
    const sels = $$(".parentesco");
    const usados = sels.map((s) => s.value).filter((v) => v && v !== "Otro");
    sels.forEach((sel) => {
      Array.from(sel.options).forEach((opt) => {
        if (!opt.value || opt.value === "Otro") { opt.disabled = false; return; }
        opt.disabled = usados.includes(opt.value) && sel.value !== opt.value;
      });
    });
  }
  $$(".parentesco").forEach((s) => s.addEventListener("change", refreshParentescos));

  // Formato de teléfono en todos los campos telefónicos
  ["celular", "resp1Tel", "resp2Tel", "emergTel"].forEach((id) => {
    const el = $("#" + id);
    if (el) el.addEventListener("input", () => { el.value = fmtPhone(el.value); });
  });

  // Validador OPCIONAL reutilizable: valida formato solo si hay contenido.
  function bindOptional(id, type) {
    const el = $("#" + id); if (!el) return;
    const wrap = el.closest("[data-field]");
    const name = wrap ? wrap.dataset.field : id;
    const run = (reveal) => {
      if (el.value.trim() === "") { setFieldState(name, "idle"); update(); return; }
      const ok = V[type](el.value);
      setFieldState(name, ok ? "valid" : (reveal ? "error" : "idle"), ERR[type]); update();
    };
    el.addEventListener("input", () => run(false));
    el.addEventListener("blur", () => run(true));
    el._isValidOptional = () => el.value.trim() === "" || V[type](el.value);
  }

  // Validador de correo: fuerza minúsculas y detecta dominios mal escritos.
  function bindEmail(id, required) {
    const el = $("#" + id); if (!el) return;
    const wrap = el.closest("[data-field]");
    const name = wrap ? wrap.dataset.field : id;
    const run = (reveal) => {
      if (el.value !== el.value.toLowerCase()) el.value = el.value.toLowerCase();
      const v = el.value.trim();
      if (v === "") { setFieldState(name, (required && reveal) ? "error" : "idle", "Este campo es obligatorio."); update(); return; }
      if (!EMAIL_RE.test(v)) { setFieldState(name, reveal ? "error" : "idle", "Correo no válido (falta @ o dominio)."); update(); return; }
      const sug = emailTipo(v);
      if (sug) { setFieldState(name, reveal ? "error" : "idle", `¿Quisiste decir “@${sug}”? Revisa el dominio.`); update(); return; }
      setFieldState(name, "valid"); update();
    };
    el.addEventListener("input", () => run(false));
    el.addEventListener("blur", () => run(true));
    el._isValid = () => V.email(el.value);
    el._isValidOptional = () => el.value.trim() === "" || V.email(el.value);
    el._validate = () => { run(true); return el._isValid(); };
  }

  // Celular y correo del ALUMNO: su obligatoriedad depende de la edad (ver applyAgeRules).
  bindOptional("celular", "tel");
  bindEmail("correo", false);

  // Edad del alumno (desde la CURP) y reglas de contacto según edad.
  function studentAge() { return state.curpInfo ? calcAge(state.curpInfo.fechaNac) : null; }
  function celReq() { const a = studentAge(); return a === null || a >= 18; }   // <18: no se pide su teléfono
  function mailReq() { const a = studentAge(); return a === null || a >= 15; }  // <15: no se pide su correo
  function applyAgeRules() {
    const a = studentAge();
    // Celular del alumno: si es menor de edad, se bloquea (no puede anotarlo) y se vacía.
    const celEl = $("#celular"), celReqEl = $('[data-field="celular"] .req'), celHint = $('[data-field="celular"] .hint');
    const celOn = celReq();
    celEl.disabled = !celOn;
    if (celReqEl) celReqEl.style.display = celOn ? "" : "none";
    if (!celOn) { celEl.value = ""; setFieldState("celular", "idle"); }
    if (celHint) { const t = celOn ? "10 dígitos" : "No aplica para menores de edad."; celHint.innerHTML = t; celHint.dataset.default = t; }
    // Correo del alumno: si es menor de 15, se bloquea y se vacía.
    const mailEl = $("#correo"), mailReqEl = $('[data-field="correo"] .req'), mailHint = $('[data-field="correo"] .hint');
    const mailOn = mailReq();
    mailEl.disabled = !mailOn;
    if (mailReqEl) mailReqEl.style.display = mailOn ? "" : "none";
    if (!mailOn) { mailEl.value = ""; setFieldState("correo", "idle"); }
    if (mailHint) {
      const t = !mailOn ? "No aplica para menores de 15 años."
        : (a !== null && a < 18) ? "Usa un correo al que el ALUMNO tenga acceso." : "";
      mailHint.innerHTML = t; mailHint.dataset.default = t;
    }
    // Mayor de edad: preguntar dependiente/independiente. Menor: reiniciar.
    if (a === null || a < 18) state.dependencia = null;
    applyDependencia();
    maybeAskDependencia();
  }

  // Dependiente / Independiente (solo aplica a mayores de 18 años).
  function resp1Req() {
    const a = studentAge();
    if (a !== null && a >= 18 && state.dependencia === "Independiente") return false; // alumno independiente
    return true;
  }
  function applyDependencia() {
    const req = resp1Req();
    ["resp1Nombre", "resp1Parentesco", "resp1Tel"].forEach((id) => {
      const r = $(`[data-field="${id}"] .req`);
      if (r) r.style.display = req ? "" : "none";
      if (!req && !$("#" + id).value) setFieldState(id, "idle");
    });
  }
  function maybeAskDependencia() {
    const a = studentAge();
    if (a !== null && a >= 18 && !state.dependencia) $("#depModal").classList.remove("hidden");
  }
  $$("#depModal [data-dep]").forEach((b) => b.addEventListener("click", () => {
    state.dependencia = b.dataset.dep;
    $("#depModal").classList.add("hidden");
    applyDependencia(); update();
  }));

  // Responsable 1 (requerido, salvo alumno independiente)
  bindField("resp1Nombre", "text");
  bindField("resp1Tel", "tel");
  bindEmail("resp1Correo", false);
  $("#resp1Parentesco").addEventListener("change", () => { setFieldState("resp1Parentesco", $("#resp1Parentesco").value ? "valid" : "error", "Selecciona el parentesco."); update(); });
  // Responsable 2 (opcional) y contacto de emergencia (OBLIGATORIO).
  bindOptional("resp2Tel", "tel");
  bindField("emergNombre", "text");
  bindField("emergTel", "tel");

  // ¿Se está llenando el Responsable 2 / el contacto de emergencia?
  function r2Used() { return !!($("#resp2Nombre").value.trim() || $("#resp2Tel").value.trim() || $("#resp2Correo").value.trim() || $("#resp2Parentesco").value); }
  function emergUsed() { return !!($("#emergNombre").value.trim() || $("#emergTel").value.trim() || $("#emergParentesco").value); }

  // La emergencia no puede ser la misma persona/teléfono que un responsable.
  const normNom = (s) => (s || "").toUpperCase().normalize("NFD").replace(/[̀-ͯ]/g, "").replace(/[^A-ZÑ]/g, "");
  const tel10 = (s) => (s || "").replace(/\D/g, "");
  function emergNameDup() {
    const e = normNom($("#emergNombre").value); if (!e) return false;
    return e === normNom($("#resp1Nombre").value) || (r2Used() && e === normNom($("#resp2Nombre").value));
  }
  function emergPhoneDup() {
    const e = tel10($("#emergTel").value); if (e.length < 10) return false;
    return e === tel10($("#resp1Tel").value) || e === tel10($("#resp2Tel").value);
  }
  // Avisos emergentes al salir de los campos de emergencia.
  $("#emergNombre").addEventListener("blur", () => { if (emergNameDup()) openModal("Contacto de emergencia inválido", "El contacto de emergencia no puede ser la misma persona que un responsable. Coloca un contacto diferente."); });
  $("#emergTel").addEventListener("blur", () => { if (emergPhoneDup()) openModal("Teléfono repetido", "El teléfono del contacto de emergencia no puede ser igual al de un responsable. Coloca un número diferente."); });

  // Marca error/válido en los campos condicionales de R2 y emergencia.
  function refreshConditionalContacts() {
    if (r2Used()) {
      setFieldState("resp2Nombre", V.text($("#resp2Nombre").value) ? "valid" : "error", "Falta el nombre.");
      setFieldState("resp2Parentesco", $("#resp2Parentesco").value ? "valid" : "error", "Selecciona el parentesco.");
    } else { setFieldState("resp2Nombre", "idle"); setFieldState("resp2Parentesco", "idle"); }
    // Emergencia (obligatoria): si está repetida con un responsable, márcalo en rojo.
    if ($("#emergNombre").value.trim() && emergNameDup()) setFieldState("emergNombre", "error", "No puede ser un responsable.");
    if ($("#emergTel").value.trim() && emergPhoneDup()) setFieldState("emergTel", "error", "No puede ser igual al de un responsable.");
  }
  bindEmail("resp2Correo", false);
  $("#resp2Nombre").addEventListener("input", update);
  $("#resp2Parentesco").addEventListener("change", update);
  $("#emergParentesco").addEventListener("change", () => { setFieldState("emergParentesco", $("#emergParentesco").value ? "valid" : "error", "Selecciona el parentesco."); update(); });

  // Salud / enfermedad (la descripción se pide solo si se activa)
  const enfToggle = $("#enfermedadToggle"), enfSwitch = $("#enfermedadSwitch"), enfBody = $("#enfermedadBody");
  $('label[for="enfermedadToggle"]').addEventListener("click", (e) => {
    e.preventDefault();
    enfToggle.checked = !enfToggle.checked;
    state.enfermedad = enfToggle.checked;
    enfSwitch.classList.toggle("on", state.enfermedad);
    enfBody.classList.toggle("hidden", !state.enfermedad);
    update();
  });
  bindOptional("enfermedadDesc", "text");

  bindField("paterno", "text");
  bindField("materno", "text");
  bindField("nombre", "text");
  bindField("calle", "text");
  bindField("numExt", "text");
  // Escuela de procedencia: campo con búsqueda (escribe número o nombre y filtra).
  $("#escuelasList").innerHTML = ESCUELAS.map((e) => `<option value="${e}"></option>`).join("");
  bindField("escuela", "text");
  function getEscuela() { return $("#escuela").value.trim(); }

  /* ---------- Verificación de iniciales contra la CURP (BLOQUEA el envío) ------
     La CURP codifica: [inicial ap. paterno][1ª vocal interna ap. paterno]
     [inicial ap. materno][inicial nombre]. Si no coinciden, NO deja enviar.
     Se contemplan casos especiales: "María José", "De la Cruz", etc. */
  const PARTICULAS = new Set(["DE", "DEL", "LA", "LAS", "LOS", "MC", "MAC", "VON", "VAN", "Y", "DI", "DA", "SAN", "SANTA"]);
  const NOMBRES_COMUNES = new Set(["MARIA", "MA", "JOSE", "J"]);
  const sinAcento = (s) => (s || "").toUpperCase().normalize("NFD").replace(/[̀-ͯ]/g, "");
  const soloLetras = (s) => sinAcento(s).replace(/[^A-ZÑ ]/g, "").trim();
  function palabraEfectiva(s) {           // primera palabra que no sea partícula
    const w = soloLetras(s).split(/\s+/).filter(Boolean);
    let i = 0;
    while (i < w.length - 1 && PARTICULAS.has(w[i])) i++;
    return w[i] || "";
  }
  function vocalInterna(w) {               // primera vocal después de la 1ª letra
    for (let i = 1; i < w.length; i++) if ("AEIOU".includes(w[i])) return w[i];
    return "X";
  }
  function letraNombre(s) {                // inicial del nombre (regla María/José)
    const w = soloLetras(s).split(/\s+/).filter(Boolean);
    if (!w.length) return "";
    if (NOMBRES_COMUNES.has(w[0]) && w[1]) return w[1][0];
    return w[0][0];
  }
  const eqLetra = (a, b) => a === b || (a === "X" && b === "Ñ") || (a === "Ñ" && b === "X");

  // Funciones de coincidencia (true = coincide o campo vacío → no bloquean aquí).
  function matchPaterno(cu) { const p = palabraEfectiva($("#paterno").value); return !p || (eqLetra(cu[0], p[0]) && eqLetra(cu[1], vocalInterna(p))); }
  function matchMaterno(cu) { const m = palabraEfectiva($("#materno").value); return !m || eqLetra(cu[2], m[0]); }
  function matchNombre(cu)  { const n = letraNombre($("#nombre").value);      return !n || eqLetra(cu[3], n); }

  function makeWarn(name) {
    const f = $(`[data-field="${name}"]`);
    const d = document.createElement("div");
    d.className = "ini-warn hidden";
    f.appendChild(d);
    return d;
  }
  const warnPat = makeWarn("paterno"), warnMat = makeWarn("materno"), warnNom = makeWarn("nombre");
  function setWarn(el, msg) {
    if (msg) { el.classList.remove("hidden"); el.innerHTML = ICON.alert + " " + msg; }
    else { el.classList.add("hidden"); el.innerHTML = ""; }
  }

  // Evalúa un campo de nombre: marca error rojo + mensaje si no coincide con la CURP.
  function evalName(id, warnEl, matchFn, letra) {
    const val = $("#" + id).value.trim();
    const cu = (curpEl.value || "").toUpperCase();
    if (val.length < 2 || !V.curp(cu)) { setWarn(warnEl, ""); if (val.length >= 2) setFieldState(id, "valid"); return; }
    if (matchFn(cu)) { setWarn(warnEl, ""); setFieldState(id, "valid"); }
    else {
      const campo = id === "paterno" ? "apellido paterno" : id === "materno" ? "apellido materno" : "nombre";
      setWarn(warnEl, `Según tu CURP, tu ${campo} debería empezar con «${cu[letra]}». Corrígelo para poder enviar.`);
      setFieldState(id, "error", "");
    }
  }
  function checkInitials() {
    evalName("paterno", warnPat, matchPaterno, 0);
    evalName("materno", warnMat, matchMaterno, 2);
    evalName("nombre",  warnNom, matchNombre,  3);
  }
  // Al salir del campo, si no coincide con la CURP, muestra ventana emergente.
  function popupField(id, matchFn, idx) {
    const cu = (curpEl.value || "").toUpperCase();
    if (V.curp(cu) && $("#" + id).value.trim() && !matchFn(cu)) {
      const campo = id === "paterno" ? "apellido paterno" : id === "materno" ? "apellido materno" : "nombre";
      openModal("Revisa el " + campo, `El ${campo} no coincide con la CURP: debería empezar con «${cu[idx]}». Corrígelo para poder enviar.`);
    }
  }
  const NAME_MATCH = { paterno: [matchPaterno, 0], materno: [matchMaterno, 2], nombre: [matchNombre, 3] };
  ["paterno", "materno", "nombre"].forEach((id) => {
    $("#" + id).addEventListener("input", checkInitials);
    $("#" + id).addEventListener("blur", () => { checkInitials(); popupField(id, NAME_MATCH[id][0], NAME_MATCH[id][1]); });
  });

  // CP autollenado (consulta SEPOMEX en línea con respaldo manual)
  const cpEl = $("#cp"), coloniaSel = $("#colonia");
  const roEstado = $('[data-ro="estado"]'), roMunicipio = $('[data-ro="municipio"]');
  const coloniaField = $('[data-field="colonia"]');
  let cpReqId = 0;

  // Campo de colonia manual: para la opción "Otra…" o cuando no hay internet.
  const coloniaOtra = document.createElement("input");
  coloniaOtra.className = "ctrl hidden";
  coloniaOtra.id = "coloniaOtra";
  coloniaOtra.placeholder = "Escribe tu colonia";
  coloniaOtra.style.marginTop = "8px";
  coloniaField.appendChild(coloniaOtra);
  coloniaOtra.addEventListener("input", update);

  // Devuelve la colonia elegida (del menú) o la escrita a mano.
  function getColonia() {
    if (!coloniaOtra.classList.contains("hidden")) return coloniaOtra.value.trim();
    return coloniaSel.value === "__otra__" ? "" : coloniaSel.value;
  }

  // Muestra estado y municipio como texto (API) o como campos editables (manual).
  function setEstadoMun(estado, municipio, editable) {
    [[roEstado, estado, "estado"], [roMunicipio, municipio, "municipio"]].forEach(([el, val, key]) => {
      if (editable) {
        el.innerHTML = '<input class="ctrl" style="border:none;background:transparent;height:auto;padding:0;width:100%" placeholder="Escríbelo">';
        el.classList.remove("empty");
        const inp = el.querySelector("input");
        inp.value = val && val !== "—" ? val : "";
        inp.addEventListener("input", () => { state.cpData = state.cpData || {}; state.cpData[key] = inp.value.trim(); update(); });
      } else {
        el.textContent = val; el.classList.remove("empty");
      }
    });
  }

  function fillColonias(colonias) {
    coloniaSel.disabled = false;
    coloniaSel.innerHTML = '<option value="">Selecciona colonia…</option>'
      + colonias.map((c) => `<option>${c}</option>`).join("")
      + '<option value="__otra__">Otra (escribir)…</option>';
    coloniaOtra.value = "";
    coloniaOtra.classList.add("hidden");
  }

  async function lookupCP(v) {
    const reqId = ++cpReqId;
    state.cpData = null;
    roEstado.textContent = "Buscando…"; roEstado.classList.remove("empty");
    roMunicipio.textContent = "Buscando…"; roMunicipio.classList.remove("empty");
    coloniaSel.disabled = true; coloniaSel.innerHTML = '<option value="">Buscando…</option>';
    coloniaOtra.classList.add("hidden");
    update();
    try {
      const resp = await fetch(CP_API + v);
      if (reqId !== cpReqId) return;            // ya se escribió un CP más nuevo
      if (!resp.ok) throw new Error("http");
      const json = await resp.json();
      const datos = (json && json.datos) || [];
      if (!datos.length) throw new Error("vacio");
      const estado = datos[0].estado, municipio = datos[0].municipio;
      const colonias = [...new Set(datos.map((d) => d.asentamiento))].sort((a, b) => a.localeCompare(b, "es"));
      state.cpData = { estado, municipio };
      setEstadoMun(estado, municipio, false);
      fillColonias(colonias);
    } catch (err) {
      if (reqId !== cpReqId) return;
      // Respaldo manual: captura estado, municipio y colonia a mano.
      state.cpData = { estado: "", municipio: "" };
      setEstadoMun("", "", true);
      coloniaSel.disabled = true;
      coloniaSel.innerHTML = '<option value="">Escríbela abajo</option>';
      coloniaOtra.classList.remove("hidden");
    }
    update();
  }

  cpEl.addEventListener("input", () => {
    cpEl.value = cpEl.value.replace(/\D/g, "").slice(0, 5);
    const v = cpEl.value;
    if (v.length < 5) { setFieldState("cp", "idle"); resetCp(); update(); return; }
    if (!V.cp(v)) { setFieldState("cp", "error", ERR.cp); resetCp(); update(); return; }
    setFieldState("cp", "valid");
    lookupCP(v);
  });
  cpEl.addEventListener("blur", () => { if (cpEl.value && !V.cp(cpEl.value)) setFieldState("cp", "error", ERR.cp); });
  function resetCp() {
    cpReqId++;
    state.cpData = null;
    roEstado.textContent = "Se completa con el CP"; roEstado.classList.add("empty");
    roMunicipio.textContent = "Se completa con el CP"; roMunicipio.classList.add("empty");
    coloniaSel.disabled = true; coloniaSel.innerHTML = '<option value="">Ingresa el CP</option>';
    coloniaOtra.value = ""; coloniaOtra.classList.add("hidden");
  }
  coloniaSel.addEventListener("change", () => {
    if (coloniaSel.value === "__otra__") { coloniaOtra.classList.remove("hidden"); coloniaOtra.focus(); }
    else { coloniaOtra.classList.add("hidden"); }
    update();
  });

  /* =================================================================
     4. Nivel de estudios (por etapas, validado contra edad y escuela)
     ================================================================= */
  const NIVELES = [
    { n: "2° de primaria", min: 6, max: 10 },
    { n: "3° de primaria", min: 7, max: 11 },
    { n: "4° de primaria", min: 8, max: 12 },
    { n: "5° de primaria", min: 9, max: 13 },
    { n: "6° de primaria", min: 10, max: 14 },
    { n: "1° de secundaria", min: 11, max: 15 },
    { n: "2° de secundaria", min: 12, max: 16 },
    { n: "3° de secundaria", min: 13, max: 17 },
    { n: "1er semestre de bachillerato", min: 14, max: 19 },
    { n: "2do semestre de bachillerato", min: 14, max: 20 },
    { n: "3er semestre de bachillerato", min: 15, max: 21 },
    { n: "4to semestre de bachillerato", min: 15, max: 22 },
    { n: "5to semestre de bachillerato", min: 16, max: 23 },
    { n: "6to semestre de bachillerato", min: 16, max: 24 },
    { n: "Universidad", min: 17, max: 99 },
    { n: "Otro", min: null, max: null },
  ];
  $("#nivel").innerHTML = '<option value="">Selecciona…</option>' + NIVELES.map((x) => `<option>${x.n}</option>`).join("");

  const nivelCat = (v) => { const s = (v || "").toLowerCase(); if (s.includes("primaria")) return "primaria"; if (s.includes("secundaria")) return "secundaria"; if (s.includes("bachillerato")) return "bachillerato"; if (s.includes("universidad")) return "universidad"; return null; };
  function escCat(e) {
    e = (e || "").trim();
    if (/^(primaria ·|prim\.)/i.test(e)) return "primaria";
    if (/^secundaria ·/i.test(e)) return "secundaria";
    if (/^(enp |cch |cecyt |cet |bachillerato)/i.test(e)) return "bachillerato";
    if (/^universidad ·/i.test(e)) return "universidad";
    return null; // escrita a mano → no se verifica
  }
  function nivelEdadOk() {
    const v = $("#nivel").value; if (!v || v === "Otro") return true;
    const info = NIVELES.find((x) => x.n === v); const a = studentAge();
    if (a == null || !info || info.min == null) return true;
    return a >= info.min && a <= info.max;
  }
  function nivelEscuelaOk() {
    const v = $("#nivel").value; if (!v || v === "Otro") return true;
    const ec = escCat(getEscuela()), nc = nivelCat(v);
    if (!ec || !nc) return true;
    return ec === nc;
  }
  // La escuela (según su nivel) debe corresponder a la edad del alumno.
  function escuelaEdadOk() {
    const ec = escCat(getEscuela()), a = studentAge();
    if (!ec || a == null) return true;
    const R = { primaria: [5, 13], secundaria: [11, 16], bachillerato: [14, 30], universidad: [17, 99] }[ec];
    return a >= R[0] && a <= R[1];
  }
  function validarNivelUI() {
    const v = $("#nivel").value;
    const escCont = !!getEscuela();
    const escEdadMal = escCont && !escuelaEdadOk();
    const nivelEdadMal = v && !nivelEdadOk();
    const mismatch = v && !nivelEscuelaOk();
    // Campo NIVEL
    if (v) {
      if (nivelEdadMal) setFieldState("nivel", "error", "La edad del alumno no corresponde al nivel seleccionado.");
      else if (mismatch) setFieldState("nivel", "error", "El nivel no coincide con la escuela de procedencia.");
      else setFieldState("nivel", "valid");
    }
    // Campo ESCUELA: solo se marca por su propia edad; el desajuste con el nivel se muestra en Nivel.
    if (escCont) {
      if (escEdadMal) setFieldState("escuela", "error", "La edad del alumno no corresponde con esta escuela.");
      else setFieldState("escuela", "valid");
    }
  }
  $("#nivel").addEventListener("change", () => {
    if (!$("#nivel").value) setFieldState("nivel", "error", "Selecciona un nivel.");
    else validarNivelUI();
    update();
  });

  /* =================================================================
     5. Cursos
     ================================================================= */
  const coursesWrap = $("#courses");
  // Iconos para la ficha de cada curso
  const ICON_META = {
    para: '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm-7 8a7 7 0 0 1 14 0"/></svg>',
    plantel: '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s7-5.5 7-11a7 7 0 1 0-14 0c0 5.5 7 11 7 11Z"/><circle cx="12" cy="10" r="2.4"/></svg>',
    periodo: '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="5" width="16" height="16" rx="2"/><path d="M4 9h16M8 3v4M16 3v4"/></svg>',
    materias: '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h9l4 4v12H6z"/><path d="M9 12h7M9 16h5"/></svg>',
  };
  // Construye la lista de datos (para quién, plantel, fechas, materias) de un curso.
  function courseMeta(c) {
    const rows = [];
    if (c.para) rows.push(["para", c.para]);
    if (c.plantel) rows.push(["plantel", "Plantel " + c.plantel]);
    if (c.periodo) rows.push(["periodo", c.periodo]);
    if (c.materias) rows.push(["materias", c.materias]);
    if (!rows.length) return "";
    return '<ul class="c-meta">' + rows.map(([k, t]) => `<li>${ICON_META[k]}<span>${t}</span></li>`).join("") + "</ul>";
  }
  // Orden: cursos abiertos arriba, cerrados al fondo (conservando su orden original).
  const coursesOrdenados = [...COURSES].sort((a, b) => (a.cerrado ? 1 : 0) - (b.cerrado ? 1 : 0));
  coursesOrdenados.forEach((c) => {
    const el = document.createElement("div");
    el.className = "course" + (c.cerrado ? " cerrado" : ""); el.dataset.course = c.id; el.tabIndex = c.cerrado ? -1 : 0;
    el.setAttribute("role", "radio"); el.setAttribute("aria-checked", "false");
    if (c.cerrado) el.setAttribute("aria-disabled", "true");
    el.innerHTML = `
      <div class="c-top">
        <span class="radio"></span>
        <span class="c-name">${c.name}</span>
        ${c.cerrado ? '<span class="type-badge cerrado-badge">Ciclo cerrado</span>' : `<span class="type-badge ${c.tipo === "Grupo" ? "grupo" : "particular"}">
          ${c.tipo === "Grupo"
            ? '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm-6 7a6 6 0 0 1 12 0M16 5a3 3 0 0 1 0 6m5 7a6 6 0 0 0-4-5.6"/></svg>'
            : '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm-7 8a7 7 0 0 1 14 0"/></svg>'}
          ${c.tipo}
        </span>`}
      </div>
      <p class="c-desc">${c.desc}</p>
      ${courseMeta(c)}
      ${c.cerrado ? '<div class="cerrado-msg">Las inscripciones de este curso están cerradas por ahora.</div>' : '<div class="course-extra"></div>'}`;
    if (!c.cerrado) {
      el.addEventListener("click", () => selectCourse(c.id));
      el.addEventListener("keydown", (e) => { if (e.key === "Enter" || e.key === " ") { e.preventDefault(); selectCourse(c.id); } });
    }
    coursesWrap.appendChild(el);
  });

  // --- Restricción de edad por curso ---
  function ageFits(c, a) {
    if (a === null) return true;                 // sin CURP aún: no se bloquea
    if (c.minEdad != null && a < c.minEdad) return false;
    if (c.maxEdad != null && a > c.maxEdad) return false;
    return true;
  }
  function courseAgeMsg(c) {
    const lo = c.minEdad, hi = c.maxEdad;
    if (lo != null && hi != null) return `El curso “${c.name}” es para edades de ${lo} a ${hi} años.`;
    if (lo != null) return `El curso “${c.name}” es para mayores de ${lo} años.`;
    if (hi != null) return `El curso “${c.name}” es para menores de ${hi} años.`;
    return "";
  }
  // Ventana emergente genérica (se reutiliza para edad, CURP y emergencia)
  function openModal(title, msg) {
    $("#ageModalTitle").textContent = title;
    $("#ageModalMsg").textContent = msg;
    $("#ageModal").classList.remove("hidden");
  }
  function openAgeModal(c, a) {
    const extra = a != null ? ` La edad del alumno es ${a} años.` : "";
    openModal("Este curso no es para esa edad", courseAgeMsg(c) + extra);
  }
  $("#ageModalClose").addEventListener("click", () => $("#ageModal").classList.add("hidden"));
  $("#ageModal").addEventListener("click", (e) => { if (e.target.id === "ageModal") $("#ageModal").classList.add("hidden"); });

  function clearCourseSelection() {
    state.course = null; state.horario = null;
    $$(".course").forEach((el) => {
      el.classList.remove("sel"); el.setAttribute("aria-checked", "false");
      const ex = el.querySelector(".course-extra"); if (ex) ex.innerHTML = "";
    });
  }
  // Si cambia la CURP y el curso ya elegido no corresponde a la edad, avisa y lo quita.
  function recheckCourseAge() {
    if (!state.course) return;
    const c = COURSES.find((x) => x.id === state.course);
    const a = studentAge();
    if (c && !ageFits(c, a)) { openAgeModal(c, a); clearCourseSelection(); update(); }
  }

  function selectCourse(id) {
    const cObj = COURSES.find((x) => x.id === id);
    if (cObj && cObj.cerrado) return;   // curso con inscripciones cerradas
    const a = studentAge();
    if (cObj && !ageFits(cObj, a)) { openAgeModal(cObj, a); return; }   // no permite elegirlo
    state.course = id; state.horario = null;
    $$(".course").forEach((el) => {
      if (el.classList.contains("cerrado")) return;   // las tarjetas cerradas no se tocan
      const on = el.dataset.course === id;
      el.classList.toggle("sel", on);
      el.setAttribute("aria-checked", on ? "true" : "false");
      const c = COURSES.find((x) => x.id === el.dataset.course);
      const extra = el.querySelector(".course-extra");
      if (!extra) return;
      if (on && c.horarioLibre) {
        extra.innerHTML = `<div class="horarios"><div class="hl">Escribe el horario acordado</div><input type="text" class="ctrl horario-libre" placeholder="Ej. Lunes y Miércoles 16:00–18:00"></div>`;
        const inp = extra.querySelector(".horario-libre");
        inp.value = (state.horario && state.horario !== "particular") ? state.horario : "";
        state.horario = inp.value.trim() || null;
        ["click", "mousedown", "keydown"].forEach((ev) => inp.addEventListener(ev, (e) => e.stopPropagation()));
        inp.addEventListener("input", () => { state.horario = inp.value.trim() || null; update(); });
      } else if (on && c.tipo === "Grupo") {
        extra.innerHTML = `<div class="horarios"><div class="hl">Elige tu horario</div><div class="pills">${c.horarios.map((h) => `<button type="button" class="pill" data-h="${h}">${h}</button>`).join("")}</div></div>`;
        extra.querySelectorAll(".pill").forEach((p) => p.addEventListener("click", (e) => {
          e.stopPropagation();
          state.horario = p.dataset.h;
          extra.querySelectorAll(".pill").forEach((x) => x.classList.toggle("sel", x === p));
          update();
        }));
      } else if (on && c.tipo === "Particular") {
        extra.innerHTML = `<div class="particular-msg"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Zm0-14v5l3.5 2"/></svg> El horario será confirmado por el equipo de Conamat.</div>`;
        state.horario = "particular";
      } else {
        extra.innerHTML = "";
      }
    });
    update();
  }

  /* =================================================================
     6 & 7. Archivos (drag & drop)
     ================================================================= */
  function fmtSize(b) { return b < 1024 * 1024 ? (b / 1024).toFixed(0) + " KB" : (b / 1024 / 1024).toFixed(1) + " MB"; }
  const MAX = 5 * 1024 * 1024;

  function setupDropzone(zoneId, inputId, chipId, stateKey, accept, onChange) {
    const zone = $("#" + zoneId), input = $("#" + inputId), chip = $("#" + chipId);
    const accepted = accept; // array of ext
    function handle(file) {
      if (!file) return;
      const ext = "." + file.name.split(".").pop().toLowerCase();
      if (!accepted.includes(ext)) { renderError(chip, "Tipo de archivo no permitido. Usa " + accepted.join(", ") + "."); state[stateKey] = null; onChange(); return; }
      if (file.size > MAX) { renderError(chip, "El archivo supera 5 MB."); state[stateKey] = null; onChange(); return; }
      state[stateKey] = { name: file.name, size: file.size, file: file };
      renderChip(chip, file, stateKey);
      onChange();
    }
    function renderChip(chip, file, key) {
      chip.style.marginTop = "14px";
      chip.innerHTML = `<div class="filechip"><div class="fc-ic">${ICON.file}</div><div class="fc-meta"><div class="fc-name">${file.name}</div><div class="fc-size">${fmtSize(file.size)} · listo para enviar</div></div><button type="button" class="fc-x" aria-label="Quitar archivo">${ICON.x}</button></div>`;
      chip.querySelector(".fc-x").addEventListener("click", () => { state[key] = null; chip.innerHTML = ""; chip.style.marginTop = "0"; input.value = ""; onChange(); });
    }
    function renderError(chip, msg) {
      chip.style.marginTop = "14px";
      chip.innerHTML = `<div class="hint err" style="font-size:13px">${ICON.info} ${msg}</div>`;
    }
    zone.addEventListener("click", () => input.click());
    zone.addEventListener("keydown", (e) => { if (e.key === "Enter" || e.key === " ") { e.preventDefault(); input.click(); } });
    input.addEventListener("change", () => handle(input.files[0]));
    ["dragenter", "dragover"].forEach((ev) => zone.addEventListener(ev, (e) => { e.preventDefault(); zone.classList.add("drag"); }));
    ["dragleave", "drop"].forEach((ev) => zone.addEventListener(ev, (e) => { e.preventDefault(); zone.classList.remove("drag"); }));
    zone.addEventListener("drop", (e) => { const f = e.dataTransfer.files[0]; if (f) handle(f); });
  }
  setupDropzone("dropzone", "fileComprobante", "comprobanteChip", "comprobante", [".pdf", ".jpg", ".jpeg", ".png"], update);
  setupDropzone("dropzoneFiscal", "fileFiscal", "fiscalChip", "fiscal", [".pdf"], update);

  /* =================================================================
     7. Factura toggle
     ================================================================= */
  const facturaToggle = $("#facturaToggle"), facturaSwitch = $("#facturaSwitch"), invoiceBody = $("#invoiceBody");
  $('label[for="facturaToggle"]').addEventListener("click", (e) => {
    e.preventDefault();
    facturaToggle.checked = !facturaToggle.checked;
    state.factura = facturaToggle.checked;
    facturaSwitch.classList.toggle("on", state.factura);
    invoiceBody.classList.toggle("hidden", !state.factura);
    update();
  });

  // poblar regímenes
  const regSel = $("#regimen");
  regSel.innerHTML = '<option value="">Selecciona…</option>' + REGIMENES.map((r) => `<option>${r}</option>`).join("");
  regSel.addEventListener("change", () => { setFieldState("regimen", regSel.value ? "valid" : "error", "Selecciona un régimen."); update(); });

  // RFC uppercase + valida
  const rfcEl = $("#rfc");
  rfcEl.addEventListener("input", () => { rfcEl.value = rfcEl.value.toUpperCase().replace(/[^A-ZÑ&0-9]/g, "").slice(0, 13); });
  bindField("rfc", "rfc");
  bindField("cpFiscal", "cp");
  bindEmail("correoFiscal", true);

  /* =================================================================
     Validación global + gating del botón
     ================================================================= */
  const REQUIRED = [
    { key: "CURP", ok: () => V.curp(curpEl.value) },
    { key: "Apellido paterno", ok: () => $("#paterno")._isValid() },
    { key: "Apellido materno", ok: () => $("#materno")._isValid() },
    { key: "Nombre(s)", ok: () => $("#nombre")._isValid() },
    { key: "Apellido paterno acorde a la CURP", ok: () => !V.curp(curpEl.value) || matchPaterno(curpEl.value.toUpperCase()) },
    { key: "Apellido materno acorde a la CURP", ok: () => !V.curp(curpEl.value) || matchMaterno(curpEl.value.toUpperCase()) },
    { key: "Nombre acorde a la CURP", ok: () => !V.curp(curpEl.value) || matchNombre(curpEl.value.toUpperCase()) },
    { key: "Celular del alumno", ok: () => !celReq() || V.tel($("#celular").value) },
    { key: "Correo del alumno", ok: () => !mailReq() || V.email($("#correo").value) },
    { key: "Código postal", ok: () => V.cp(cpEl.value) && state.cpData },
    { key: "Calle", ok: () => $("#calle")._isValid() },
    { key: "Número exterior", ok: () => $("#numExt")._isValid() },
    { key: "Nombre del Responsable 1", ok: () => !resp1Req() || $("#resp1Nombre")._isValid() },
    { key: "Parentesco del Responsable 1", ok: () => !resp1Req() || !!$("#resp1Parentesco").value },
    { key: "Teléfono del Responsable 1", ok: () => !resp1Req() || $("#resp1Tel")._isValid() },
    { key: "Correo del Responsable 1 válido", ok: () => $("#resp1Correo")._isValidOptional() },
    { key: "Nombre del Responsable 2", ok: () => !r2Used() || V.text($("#resp2Nombre").value) },
    { key: "Parentesco del Responsable 2", ok: () => !r2Used() || !!$("#resp2Parentesco").value },
    { key: "Teléfono del Responsable 2 válido", ok: () => $("#resp2Tel")._isValidOptional() },
    { key: "Nombre del contacto de emergencia", ok: () => V.text($("#emergNombre").value) && !emergNameDup() },
    { key: "Parentesco del contacto de emergencia", ok: () => !!$("#emergParentesco").value },
    { key: "Teléfono del contacto de emergencia", ok: () => V.tel($("#emergTel").value) && !emergPhoneDup() },
    { key: "Escuela de procedencia", ok: () => !!getEscuela() },
    { key: "Nivel de estudios", ok: () => !!$("#nivel").value },
    { key: "Nivel y escuela acordes a la edad", ok: () => nivelEdadOk() && nivelEscuelaOk() && escuelaEdadOk() },
    { key: "Curso", ok: () => !!state.course },
    { key: "Horario del curso", ok: () => !!state.horario },
    { key: "Descripción de enfermedad", ok: () => !state.enfermedad || V.text($("#enfermedadDesc").value) },
    { key: "Comprobante de pago", ok: () => !!state.comprobante },
  ];
  const INVOICE_REQ = [
    { key: "RFC", ok: () => $("#rfc")._isValid() },
    { key: "CP fiscal", ok: () => $("#cpFiscal")._isValid() },
    { key: "Régimen fiscal", ok: () => !!regSel.value },
    { key: "Correo de factura", ok: () => $("#correoFiscal")._isValid() },
  ];

  // mapa sección → llaves requeridas para marcar "completa"
  const SEC_REQ = {
    "sec-ident": ["CURP", "Apellido paterno", "Apellido materno", "Nombre(s)", "Apellido paterno acorde a la CURP", "Apellido materno acorde a la CURP", "Nombre acorde a la CURP"],
    "sec-contacto": ["Celular del alumno", "Correo del alumno", "Código postal", "Calle", "Número exterior"],
    "sec-tutor": ["Nombre del Responsable 1", "Parentesco del Responsable 1", "Teléfono del Responsable 1", "Correo del Responsable 1 válido", "Nombre del Responsable 2", "Parentesco del Responsable 2", "Teléfono del Responsable 2 válido", "Nombre del contacto de emergencia", "Parentesco del contacto de emergencia", "Teléfono del contacto de emergencia", "Descripción de enfermedad"],
    "sec-academico": ["Escuela de procedencia", "Nivel de estudios", "Nivel y escuela acordes a la edad"],
    "sec-curso": ["Curso", "Horario del curso"],
    "sec-comprobante": ["Comprobante de pago"],
  };

  const submitBtn = $("#submitBtn"), submitNote = $("#submitNote"), missingBox = $("#missingBox");

  function update() {
    refreshConditionalContacts();
    validarNivelUI();
    const reqs = REQUIRED.concat(state.factura ? INVOICE_REQ : []);
    const results = {};
    reqs.forEach((r) => { results[r.key] = r.ok(); });
    const missing = reqs.filter((r) => !results[r.key]).map((r) => r.key);

    // progreso
    const total = reqs.length, done = total - missing.length;
    const pct = Math.round((done / total) * 100);
    $("#progressFill").style.width = pct + "%";
    $("#progressPct").textContent = pct + "%";

    // estado por sección
    Object.entries(SEC_REQ).forEach(([secId, keys]) => {
      const sec = $("#" + secId);
      const allOk = keys.every((k) => results[k] !== false && results[k] !== undefined ? results[k] : (results[k] === undefined ? true : results[k]));
      const ok = keys.every((k) => results[k]);
      sec.classList.toggle("complete", ok);
      const st = sec.querySelector("[data-status]");
      st.innerHTML = ok ? '<span class="renapo-badge" style="background:var(--green-soft);color:var(--green-press)"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5 10 17.5 19.5 7"/></svg> Completo</span>' : "";
    });
    // factura section completeness
    const facSec = $("#sec-factura");
    if (state.factura) {
      const ok = INVOICE_REQ.every((r) => results[r.key]);
      facSec.classList.toggle("complete", ok);
    } else { facSec.classList.remove("complete"); }

    const allOk = missing.length === 0;
    submitBtn.disabled = !allOk;
    if (allOk) {
      submitNote.className = "submit-note";
      submitNote.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5 10 17.5 19.5 7"/></svg> Todo listo para enviar';
      missingBox.innerHTML = "";
    } else {
      submitNote.className = "submit-note blocked";
      submitNote.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M7 11V8a5 5 0 0 1 10 0v3M5 11h14v9H5z"/></svg> Faltan ' + missing.length + ' dato' + (missing.length === 1 ? "" : "s") + " para habilitar el envío";
      // Lista en vivo de lo que falta
      missingBox.innerHTML = '<div class="missing"><b>Faltan estos datos:</b><ul>' + missing.map((m) => `<li>${m}</li>`).join("") + "</ul></div>";
    }
    state._missing = missing;
    saveDraft();
  }

  /* =================================================================
     Envío
     ================================================================= */
  // Lee un File y lo devuelve como base64 (sin el prefijo data:).
  function fileToBase64(file) {
    return new Promise((resolve, reject) => {
      if (!file || !file.file) { resolve(null); return; }
      const r = new FileReader();
      r.onload = () => resolve({ nombre: file.name, mime: file.file.type || "application/octet-stream", base64: String(r.result).split(",")[1] });
      r.onerror = reject;
      r.readAsDataURL(file.file);
    });
  }

  // Reúne todos los datos capturados en un objeto plano.
  function buildPayload() {
    const v = (id) => { const el = $("#" + id); return el ? el.value.trim() : ""; };
    const courseObj = COURSES.find((c) => c.id === state.course);
    const datos = {
      ciclo: CICLO,
      curp: v("curp"),
      apellidoPaterno: v("paterno"),
      apellidoMaterno: v("materno"),
      nombre: v("nombre"),
      fechaNacimiento: state.curpInfo ? state.curpInfo.fechaNac : "",
      sexo: state.curpInfo ? state.curpInfo.sexo : "",
      edad: state.curpInfo ? calcAge(state.curpInfo.fechaNac) : "",
      celular: v("celular"),
      correo: v("correo"),
      cp: v("cp"),
      estado: state.cpData ? state.cpData.estado : "",
      municipio: state.cpData ? state.cpData.municipio : "",
      colonia: getColonia(),
      calle: v("calle"),
      numExt: v("numExt"),
      numInt: v("numInt"),
      dependencia: state.curpInfo && calcAge(state.curpInfo.fechaNac) >= 18 ? (state.dependencia || "") : "Menor de edad",
      resp1Nombre: v("resp1Nombre"),
      resp1Parentesco: $("#resp1Parentesco").value,
      resp1Tel: v("resp1Tel"),
      resp1Correo: v("resp1Correo"),
      resp2Nombre: v("resp2Nombre"),
      resp2Parentesco: $("#resp2Parentesco").value,
      resp2Tel: v("resp2Tel"),
      resp2Correo: v("resp2Correo"),
      enfermedad: state.enfermedad ? "Sí" : "No",
      enfermedadDesc: state.enfermedad ? v("enfermedadDesc") : "",
      emergencia: v("emergNombre"),
      emergParentesco: $("#emergParentesco").value,
      telEmergencia: v("emergTel"),
      escuela: getEscuela(),
      nivel: $("#nivel").value,
      curso: courseObj ? courseObj.name : "",
      horario: state.horario === "particular" ? "Por confirmar (clase particular)" : (state.horario || ""),
      requiereFactura: state.factura ? "Sí" : "No",
      rfc: state.factura ? v("rfc") : "",
      cpFiscal: state.factura ? v("cpFiscal") : "",
      regimenFiscal: state.factura ? regSel.value : "",
      correoFiscal: state.factura ? v("correoFiscal") : "",
      enviadoEn: new Date().toISOString(),
    };
    // Todos los datos en MAYÚSCULAS, excepto los correos.
    const noUpper = new Set(["correo", "resp1Correo", "resp2Correo", "correoFiscal", "enviadoEn", "fechaNacimiento"]);
    Object.keys(datos).forEach((k) => {
      if (!noUpper.has(k) && typeof datos[k] === "string") datos[k] = datos[k].toUpperCase();
    });
    return datos;
  }

  function finishOk(folio, nombreCompleto) {
    $("#confirmFolio").textContent = folio;
    if (nombreCompleto) $("#confirmLead").innerHTML = `Recibimos la preinscripción de <b>${nombreCompleto}</b>. El equipo de CONAMAT revisará los datos; recuerda acudir al plantel para completar el proceso.`;
    // Aviso unificado: mensaje según la edad real + detalles del curso + horario.
    const edadAlumno = state.curpInfo ? calcAge(state.curpInfo.fechaNac) : null;
    let base = "Esta es una <b>preinscripción</b>. Para completar tu inscripción deberás acudir al plantel a firmar los documentos <b>a más tardar 1 semana antes de la fecha de inicio del curso</b>.";
    if (edadAlumno !== null && edadAlumno < 18) base += " Por ser menor de edad, el alumno deberá presentarse acompañado de un adulto (padre, madre o tutor).";
    const extras = [];
    const cObjNota = COURSES.find((c) => c.id === state.course);
    if (cObjNota && cObjNota.notas) cObjNota.notas.forEach((n) => extras.push(n));
    extras.push("Horario de atención en plantel: <b>lunes a viernes de 8:00 a 20:00 h</b>; <b>sábado y domingo de 9:00 a 13:00 h</b>.");
    $("#confirmNoteDesc").innerHTML = base
      + "<ul style='margin:8px 0 0;padding-left:18px'>" + extras.map((e) => `<li style='margin:3px 0'>${e}</li>`).join("") + "</ul>";
    try { localStorage.removeItem(DRAFT_KEY); } catch (_) {}
    $("#formView").classList.add("hidden");
    $("#confirmView").classList.remove("hidden");
    window.scrollTo(0, 0);
  }

  function submitError(msg) {
    submitBtn.disabled = false;
    submitBtn.querySelector("#submitLabel").textContent = "Enviar inscripción";
    const spin = submitBtn.querySelector(".spin"); if (spin) spin.remove();
    submitNote.className = "submit-note blocked";
    submitNote.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 1.5 21h21L12 3Zm0 6v6m0 3v.5"/></svg> ' + msg;
  }

  $("#form").addEventListener("submit", async (e) => {
    e.preventDefault();
    if (submitBtn.disabled) {
      // revelar errores
      ["paterno", "materno", "nombre", "calle", "numExt"].forEach((id) => $("#" + id)._validate && $("#" + id)._validate());
      if (celReq() && !V.tel($("#celular").value)) setFieldState("celular", "error", ERR.tel);
      if (mailReq() && !V.email($("#correo").value)) setFieldState("correo", "error", ERR.email);
      if (resp1Req()) {
        $("#resp1Nombre")._validate(); $("#resp1Tel")._validate();
        if (!$("#resp1Parentesco").value) setFieldState("resp1Parentesco", "error", "Selecciona el parentesco.");
      }
      if (!getEscuela()) setFieldState("escuela", "error", "Selecciona o escribe tu escuela.");
      $("#emergNombre")._validate(); $("#emergTel")._validate();
      if (!$("#emergParentesco").value) setFieldState("emergParentesco", "error", "Selecciona el parentesco.");
      if (state.enfermedad && !V.text($("#enfermedadDesc").value)) setFieldState("enfermedadDesc", "error", "Describe la condición.");
      checkInitials();
      if (!$("#nivel").value) setFieldState("nivel", "error", "Selecciona un nivel."); else validarNivelUI();
      // mostrar lista de faltantes
      if (state._missing && state._missing.length) {
        missingBox.innerHTML = '<div class="missing"><b>Para enviar, completa:</b><ul>' + state._missing.map((m) => `<li>${m}</li>`).join("") + "</ul></div>";
      }
      return;
    }
    // Todo válido: mostrar la tabla de confirmación antes de enviar.
    showConfirmModal();
  });

  // Construye y muestra la ventana con el resumen de datos del alumno.
  function escapeHtml(s) { return String(s).replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c])); }
  function showConfirmModal() {
    const p = buildPayload();
    const rows = [];
    const add = (k, v) => { if (v != null && String(v).trim() !== "") rows.push([k, String(v)]); };
    add("Nombre", `${p.nombre} ${p.apellidoPaterno} ${p.apellidoMaterno}`.replace(/\s+/g, " ").trim());
    add("CURP", p.curp);
    add("Nacimiento", [p.fechaNacimiento ? fmtDate(p.fechaNacimiento) : "", p.edad !== "" ? p.edad + " años" : "", p.sexo].filter(Boolean).join(" · "));
    if (p.dependencia && p.dependencia !== "Menor de edad") add("Tipo de alumno", p.dependencia);
    add("Celular del alumno", p.celular);
    add("Correo del alumno", p.correo);
    add("Domicilio", [[p.calle, p.numExt].filter(Boolean).join(" "), p.numInt ? "Int. " + p.numInt : "", p.colonia, p.cp, p.municipio, p.estado].filter(Boolean).join(", "));
    add("Responsable 1", `${p.resp1Nombre}${p.resp1Parentesco ? " (" + p.resp1Parentesco + ")" : ""}${p.resp1Tel ? " · " + p.resp1Tel : ""}`);
    if (p.resp2Nombre) add("Responsable 2", `${p.resp2Nombre}${p.resp2Parentesco ? " (" + p.resp2Parentesco + ")" : ""}${p.resp2Tel ? " · " + p.resp2Tel : ""}`);
    if (p.emergencia) add("Emergencia", `${p.emergencia}${p.emergParentesco ? " (" + p.emergParentesco + ")" : ""}${p.telEmergencia ? " · " + p.telEmergencia : ""}`);
    add("Escuela", p.escuela);
    add("Nivel", p.nivel);
    add("Curso", `${p.curso}${p.horario ? " · " + p.horario : ""}`);
    if (p.enfermedad === "Sí") add("Enfermedad", p.enfermedadDesc || "Sí");
    if (p.requiereFactura === "Sí") add("Factura", "RFC " + p.rfc);
    $("#confirmTableBody").innerHTML = rows.map(([k, v]) => `<tr><th>${k}</th><td>${escapeHtml(v)}</td></tr>`).join("");
    $("#confirmDataModal").classList.remove("hidden");
  }
  $("#confirmEditBtn").addEventListener("click", () => $("#confirmDataModal").classList.add("hidden"));
  $("#confirmDataModal").addEventListener("click", (e) => { if (e.target.id === "confirmDataModal") $("#confirmDataModal").classList.add("hidden"); });
  $("#confirmSendBtn").addEventListener("click", () => { $("#confirmDataModal").classList.add("hidden"); doSubmit(); });

  // Envío real (tras confirmar en la ventana).
  async function doSubmit() {
    submitBtn.disabled = true;
    submitBtn.querySelector("#submitLabel").textContent = "Enviando…";
    submitBtn.insertAdjacentHTML("afterbegin", ICON.spin);

    const payload = buildPayload();
    const nombreCompleto = `${payload.nombre} ${payload.apellidoPaterno}`.trim();
    const folioLocal = "INS-2026-" + Math.floor(10000 + Math.random() * 89999);

    // Modo demostración: sin endpoint configurado, no se guarda nada.
    if (!ENDPOINT) {
      setTimeout(() => finishOk(folioLocal + " (demo)", nombreCompleto), 900);
      return;
    }

    try {
      const [comprobante, fiscal] = await Promise.all([
        fileToBase64(state.comprobante),
        fileToBase64(state.fiscal),
      ]);
      payload.folio = folioLocal;          // el servidor guarda el mismo folio que ve el alumno
      payload.comprobante = comprobante;   // {nombre, mime, base64} | null
      payload.constanciaFiscal = fiscal;

      // no-cors + text/plain: Apps Script no devuelve cabeceras CORS legibles,
      // así que enviamos sin leer la respuesta. El folio se genera aquí.
      await fetch(ENDPOINT, {
        method: "POST",
        mode: "no-cors",
        headers: { "Content-Type": "text/plain;charset=utf-8" },
        body: JSON.stringify(payload),
      });
      finishOk(folioLocal, nombreCompleto);
    } catch (err) {
      submitError("No pudimos enviar tu inscripción (" + (err.message || "error de red") + "). Revisa tu conexión e inténtalo de nuevo.");
    }
  }

  /* =================================================================
     Borrador automático — guarda el avance en el navegador
     ================================================================= */
  const DRAFT_KEY = "conamat_inscripcion_draft_v1";
  const DRAFT_IDS = ["curp", "paterno", "materno", "nombre", "celular", "correo", "cp", "colonia", "calle", "numExt", "numInt", "resp1Nombre", "resp1Parentesco", "resp1Tel", "resp1Correo", "resp2Nombre", "resp2Parentesco", "resp2Tel", "resp2Correo", "enfermedadDesc", "emergNombre", "emergParentesco", "emergTel", "escuela", "nivel", "rfc", "cpFiscal", "regimen", "correoFiscal"];
  let draftTimer = null;
  function saveDraft() {
    clearTimeout(draftTimer);
    draftTimer = setTimeout(() => {
      const d = { factura: state.factura, enfermedad: state.enfermedad, course: state.course, horario: state.horario };
      DRAFT_IDS.forEach((id) => { const el = $("#" + id); if (el) d[id] = el.value; });
      try { localStorage.setItem(DRAFT_KEY, JSON.stringify(d)); } catch (_) {}
    }, 400);
  }
  function restoreDraft() {
    let d; try { d = JSON.parse(localStorage.getItem(DRAFT_KEY) || "null"); } catch (_) { d = null; }
    if (!d) return;
    if (d.factura) $('label[for="facturaToggle"]').click();      // abre la sección de factura
    if (d.enfermedad) $('label[for="enfermedadToggle"]').click(); // abre la descripción de enfermedad
    const order = ["curp", "cp", "colonia", "nivel", "regimen"].concat(DRAFT_IDS);
    const seen = new Set();
    order.forEach((id) => {
      if (seen.has(id)) return; seen.add(id);
      const el = $("#" + id); if (!el || d[id] == null || d[id] === "") return;
      el.value = d[id];
      el.dispatchEvent(new Event(el.tagName === "SELECT" ? "change" : "input", { bubbles: true }));
    });
    if (d.course) {
      selectCourse(d.course);
      if (d.horario && d.horario !== "particular") {
        const pill = $(`#courses .pill[data-h="${d.horario}"]`);
        if (pill) pill.click();
        const li = $("#courses .horario-libre");
        if (!pill && li) { li.value = d.horario; state.horario = d.horario; update(); }
      }
    }
  }

  // init
  restoreDraft();
  applyAgeRules();
  refreshParentescos();
  update();
})();

</script>


